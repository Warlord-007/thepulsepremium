# ============================================================
#  ThePulsePremium — Callboard + Free AI Configuration
#  Copy this to .env and fill in your values.
# ============================================================

# ── GOOGLE GEMINI (FREE — 15 req/min, no credit card) ─────
# Get your free key: https://aistudio.google.com/app/apikey
# 1. Sign in with any Google account
# 2. Click "Create API key" — done, completely free
VITE_GEMINI_API_KEY=paste_your_free_gemini_key_here

# ── POLLINATIONS.AI (100% FREE — no key needed) ────────────
# Already works with no setup. Used as automatic fallback.
VITE_POLLINATIONS_ENABLED=true

# ── CALLBOARD (optional — for memory + cron jobs) ──────────
# Get key at https://callboard.ai
# Leave blank to use free Gemini/Pollinations instead
VITE_CALLBOARD_API_KEY=
CALLBOARD_API_KEY=
CALLBOARD_PROJECT_ID=thepulsepremium

# ── AGENT IDs ──────────────────────────────────────────────
AGENT_CONCIERGE_ID=premium-concierge
AGENT_STRATEGIST_ID=viral-strategist

# ── AI MODEL BACKEND ───────────────────────────────────────
ANTHROPIC_API_KEY=

# ── MEMORY / STORAGE ───────────────────────────────────────
CALLBOARD_MEMORY_BACKEND=redis
REDIS_URL=redis://localhost:6379

# ── CRON JOBS ──────────────────────────────────────────────
CRON_TIMEZONE=America/New_York

# ── SERVER ─────────────────────────────────────────────────
PORT=4000
VITE_API_URL=/api
ALLOWED_ORIGINS=http://localhost:3000,https://thepulsepremium.com

# ── WEBHOOKS ───────────────────────────────────────────────
WEBHOOK_SECRET=change_this_to_a_random_string
WEBHOOK_URL=https://thepulsepremium.com/api/webhooks/callboard

# ── N8N AUTOMATION ─────────────────────────────────────────
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook
